{
  "name": "core-api",
  "version": "0.0.0",
  "private": true,
  "_moduleAliases": {
    "@root": ".",
    "@": "./src"
  },
  "scripts": {
    "start": "npm run serve:prod",
    "serve:dev": "set NODE_ENV=development&&set DEBUG=core-api:*&&nodemon ./src/index",
    "serve:prod": "set NODE_ENV=production&&node ./src/index"
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^16.4.5",
    "express": "~4.16.1",
    "express-validator": "^7.0.1",
    "http-errors": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "morgan": "~1.9.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
